{
  "name": "glowing-postcard",
  "version": "1.0.0",
  "description": "动态光影明信片应用",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "ts-node --project tsconfig.server.json src/server/index.ts",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.0",
    "bcrypt": "^5.1.0",
    "gsap": "^3.12.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/uuid": "^9.0.2",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^20.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.1.0",
    "vite": "^4.4.0",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.1"
  }
}
