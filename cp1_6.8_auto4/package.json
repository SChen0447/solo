{
  "name": "team-sticky-board",
  "version": "1.0.0",
  "description": "在线协作的团队便签板",
  "type": "module",
  "scripts": {
    "dev:server": "ts-node --esm server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
