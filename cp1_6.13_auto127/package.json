{
  "name": "taste-quantum-menu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "味觉·量子菜单 - 分子料理创意菜品生成应用",
  "scripts": {
    "dev:front": "vite",
    "dev:back": "ts-node --esm server/index.ts",
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:back\"",
    "build": "tsc -b && vite build",
    "build:back": "tsc --project server/tsconfig.json",
    "lint": "eslint .",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.0",
    "lucide-react": "^0.511.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.15.30",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "sass": "^1.69.0",
    "ts-node": "^10.9.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.30.1",
    "globals": "^16.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
