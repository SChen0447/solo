    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "better-sqlite3": "11.3.0",
    "cors": "2.8.5"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/express": "4.17.21",
    "@types/bcryptjs": "2.4.6",
    "@types/jsonwebtoken": "9.0.6",
    "@types/better-sqlite3": "7.6.11",
    "@types/cors": "2.8.17",
    "@types/node": "20.14.0",
    "typescript": "5.5.0",
    "vite": "5.4.0",
