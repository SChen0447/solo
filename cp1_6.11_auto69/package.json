    "react-router-dom": "^6.22.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "json-server": "^1.0.0-alpha.23",
    "typescript": "~5.8.3",
    "vite": "^5.4.11"
  }
}
