{
  "name": "soundwave-tracks",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "声浪·轨迹 - 互动式巡演路线规划与粉丝应援墙平台",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "ts-node --esm server/index.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "zustand": "^4.5.0",
    "lucide-react": "^0.344.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.4.0",
    "vite": "^5.4.0",
    "sass": "^1.70.0",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "eslint": "^9.25.0",
    "@eslint/js": "^9.25.0",
    "typescript-eslint": "^8.30.1",
    "globals": "^16.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
