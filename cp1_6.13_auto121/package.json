{
  "name": "chenfeng-shujian-jiemi",
  "private": true,
  "version": "1.0.0",
  "description": "尘封·书简解密 - 先秦典故拼合解密游戏",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "ts-node --project tsconfig.node.json src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "gsap": "^3.12.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.17",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "sass": "^1.70.0",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
