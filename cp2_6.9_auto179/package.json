{
  "name": "tour-manager",
  "version": "1.0.0",
  "description": "Tour schedule and setlist management for independent musicians",
  "main": "dist/server/server.js",
  "scripts": {
    "dev": "concurrently \"tsc && node dist/server/server.js\" \"vite\"",
    "build": "tsc && vite build",
    "start": "node dist/server/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "ws": "^8.14.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.9",
    "concurrently": "^8.2.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
