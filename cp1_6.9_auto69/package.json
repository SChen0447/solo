{
  "name": "fairy-tale-emotion-book",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "tsx watch server/server.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.21.0",
    "express": "4.18.2",
    "cors": "2.8.5",
    "three": "0.160.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/express": "4.17.21",
    "@types/cors": "^2.8.17",
    "@types/three": "^0.160.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "5.5.0",
    "vite": "5.4.0",
    "vite-tsconfig-paths": "^4.2.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0"
  }
}
