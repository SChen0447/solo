{
  "name": "ancient-book-bazaar",
  "version": "1.0.0",
  "description": "在线虚拟古籍兑换市集与藏书家日志",
  "scripts": {
    "dev": "npx concurrently \"npm run server\" \"npm run client\"",
    "server": "npx nodemon --exec \"npx ts-node -P ./server/tsconfig.json ./server/index.ts\"",
    "client": "npx vite"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "framer-motion": "^10.16.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.4"
  }
}
