{
  "name": "leather-workshop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:front": "vite",
    "dev:back": "ts-node-dev --respawn --transpile-only src/backend/server.ts",
    "dev": "concurrently \"npm run dev:front\" \"npm run dev:back\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.0.4",
    "vite": "^5.1.4",
    "@vitejs/plugin-react": "^4.2.1",
    "ts-node-dev": "^2.0.0",
    "concurrently": "^8.2.2"
  }
}
