{
  "name": "virtual-bookshelf",
  "version": "1.0.0",
  "description": "在线虚拟书架展示与收藏管理全栈项目",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node --project tsconfig.server.json server/index.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/uuid": "^9.0.7",
    "@types/cors": "^2.8.17",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.1"
  }
}
