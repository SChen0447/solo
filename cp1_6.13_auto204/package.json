{
  "name": "capsule-light-sound-archive",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c magenta,cyan \"tsx src/server/server.ts\" \"vite\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.19.2",
    "uuid": "^9.0.1",
    "cors": "^2.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.8",
    "@types/cors": "^2.8.17",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "tsx": "^4.16.0",
    "concurrently": "^8.2.2"
  }
}
