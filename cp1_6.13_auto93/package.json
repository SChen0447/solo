{
  "name": "gesture-sound-workshop",
  "version": "1.0.0",
  "description": "手势谱·音轨工坊 - 用手势创作视觉音乐",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node --esm src/backend/sequencer.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@mediapipe/hands": "^0.4.1675469240",
    "three": "^0.160.0",
    "gsap": "^3.12.5",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/three": "^0.160.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
