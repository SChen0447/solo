    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "chart.js": "^4.4.6",
    "react-chartjs-2": "^5.2.0",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.19",
    "@types/body-parser": "^1.19.5",
    "@types/node": "^22.15.30",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "tsx": "^4.20.3",
    "concurrently": "^9.2.0"
  }
