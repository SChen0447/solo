{
  "name": "sky-islands",
  "version": "1.0.0",
  "description": "Virtual Sky Islands Chain Builder",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx src/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.18.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "three": "0.160.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/three": "0.160.0",
    "@vitejs/plugin-react": "4.2.0",
    "concurrently": "8.2.2",
    "tsx": "4.7.0",
    "typescript": "5.4.5",
    "vite": "5.4.0"
  }
}
