{
  "name": "mohen-shijian",
  "version": "1.0.0",
  "description": "墨痕·诗笺 - 在虚拟宣纸上书写汉字，匹配古诗生成电子诗笺",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node src/backend/server.ts",
    "build": "tsc -b && vite build",
    "start": "node dist/backend/server.js",
    "install:all": "npm install"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "axios": "^1.6.7",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "sass": "^1.70.0",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
