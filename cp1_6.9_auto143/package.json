{
  "name": "flower-language-cipher",
  "version": "1.0.0",
  "description": "虚拟花语密码与数字标本馆",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/src/app.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.0",
    "cors": "2.8.5",
    "mongoose": "8.0.0"
  },
  "devDependencies": {
    "typescript": "5.5.0",
    "vite": "5.4.0",
    "@vitejs/plugin-react": "4.3.1",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/express": "4.17.0",
    "@types/cors": "2.8.0",
    "@types/node": "20.0.0",
    "concurrently": "8.2.0",
    "tsx": "4.0.0"
  }
}
