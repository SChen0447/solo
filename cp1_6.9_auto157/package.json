{
  "name": "ink-library",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsx server/index.ts",
    "start": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "^6.20.0",
    "express": "4.18.0",
    "cors": "2.8.5",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "4.0.0",
    "typescript": "5.5.0",
    "vite": "5.4.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0"
  }
}
