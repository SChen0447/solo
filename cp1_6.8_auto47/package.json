{
  "name": "audio-visualizer",
  "version": "1.0.0",
  "description": "Audio to visual music waveform animation converter",
  "main": "server/server.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "ts-node server/server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/fluent-ffmpeg": "^2.1.24",
    "ts-node": "^10.9.1",
    "concurrently": "^8.2.2"
  }
}
