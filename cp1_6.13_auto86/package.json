{
  "name": "mystery-flower-blinds",
  "version": "1.0.0",
  "description": "秘境花语·盲盒社交 - 线上交换卡片应用",
  "private": true,
  "workspaces": [
    "src/frontend",
    "src/backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node src/backend/server.ts",
    "build": "tsc -p src/frontend && tsc -p src/backend && vite build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "react-beautiful-dnd": "^13.1.1",
    "styled-components": "^6.1.0",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "sharp": "^0.33.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "concurrently": "^8.2.2"
  }
}
