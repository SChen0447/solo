  "dishes": [
    {
      "id": "dish-001",
      "name": "番茄炒蛋",
      "description": "经典家常菜，酸甜可口，百吃不厌。简单的食材，不简单的味道。",
      "ingredients": ["番茄 2个", "鸡蛋 3个", "葱花 适量", "盐 少许", "白砂糖 1勺", "食用油 适量"],
      "ingredientsHighlight": ["番茄", "鸡蛋"],
      "steps": [
        {
          "id": "step-1",
          "title": "准备食材",
          "content": "番茄洗净切块，鸡蛋打入碗中加少许盐打散，葱花切好备用。",
          "duration": 5
        },
        {
          "id": "step-2",
          "title": "炒鸡蛋",
          "content": "热锅放油，油温六成热时倒入蛋液，用筷子快速划散，炒至金黄色盛出备用。",
          "duration": 3
        },
        {
          "id": "step-3",
          "title": "炒番茄",
          "content": "锅内留底油，放入番茄块中火翻炒，加入一勺白糖和少许盐，炒出番茄汁。",
          "duration": 4
        },
        {
          "id": "step-4",
          "title": "混合翻炒",
          "content": "倒入炒好的鸡蛋，快速翻炒均匀，让鸡蛋充分吸收番茄汁，撒上葱花即可出锅。",
          "duration": 2
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=400&h=300&fit=crop",
      "rating": 4.7,
      "ratingCount": 128,
      "likes": 256,
      "comments": [
        {
