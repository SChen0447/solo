    {
      "id": "dish-003",
      "name": "蒜蓉西兰花",
      "description": "清爽健康的素食小菜，翠绿诱人，蒜香浓郁。",
      "ingredients": ["西兰花 1颗", "大蒜 5瓣", "盐 适量", "蚝油 1勺", "食用油 适量"],
      "ingredientsHighlight": ["西兰花", "大蒜"],
      "steps": [
        {
          "id": "step-1",
          "title": "处理西兰花",
          "content": "西兰花掰成小朵，用淡盐水浸泡10分钟后冲洗干净。",
          "duration": 12
        },
        {
          "id": "step-2",
          "title": "焯水",
          "content": "烧开水，加少许盐和油，放入西兰花焯水1分钟，捞出过凉水沥干。",
          "duration": 3
        },
        {
          "id": "step-3",
          "title": "爆香蒜末",
          "content": "热锅放油，小火慢慢爆香蒜末至金黄色。",
          "duration": 2
        },
        {
          "id": "step-4",
          "title": "快速翻炒",
          "content": "倒入西兰花，加蚝油和盐，大火快速翻炒均匀即可出锅。",
          "duration": 2
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1459411552884-841db9b3cc2a?w=400&h=300&fit=crop",
      "rating": 4.5,
      "ratingCount": 67,
      "likes": 189,
      "comments": [],
