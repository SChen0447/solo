    {
      "id": "dish-002",
      "name": "红烧肉",
      "description": "肥而不腻，入口即化的经典红烧肉。色泽红亮，香气四溢。",
      "ingredients": ["五花肉 500g", "冰糖 30g", "生抽 2勺", "老抽 1勺", "料酒 2勺", "姜片 3片", "八角 2个", "桂皮 1小段"],
      "ingredientsHighlight": ["五花肉", "冰糖"],
      "steps": [
        {
          "id": "step-1",
          "title": "处理五花肉",
          "content": "五花肉切块，冷水下锅焯水，加料酒和姜片去腥，撇去浮沫后捞出沥干。",
          "duration": 10
        },
        {
          "id": "step-2",
          "title": "炒糖色",
          "content": "冷锅放油，加入冰糖小火慢慢炒化，炒至枣红色冒小泡。",
          "duration": 5
        },
        {
          "id": "step-3",
          "title": "上色翻炒",
          "content": "倒入焯好水的五花肉，快速翻炒均匀，让每块肉都裹上糖色。",
          "duration": 3
        },
        {
          "id": "step-4",
          "title": "炖煮",
          "content": "加入生抽、老抽、料酒、八角、桂皮，加热水没过肉，大火烧开转小火炖60分钟。",
          "duration": 60
        },
        {
          "id": "step-5",
          "title": "收汁",
          "content": "大火收汁，待汤汁浓稠裹满肉块即可出锅。",
          "duration": 8
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1544025162-d76694265947?w=400&h=300&fit=crop",
      "rating": 4.9,
      "ratingCount": 89,
      "likes": 412,
      "comments": [
        {
          "id": "comment-3",
          "author": "吃货阿杰",
          "avatar": "https://api.dicebear.com/7.x/initials/svg?seed=%E6%9D%B0",
          "content": "太绝了！第一次做红烧肉就成功了，家人都说好吃！",
          "createdAt": "2024-01-12T18:30:00.000Z"
        }
      ],
