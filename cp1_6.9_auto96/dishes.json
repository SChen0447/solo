    {
      "id": "dish-005",
      "name": "糖醋排骨",
      "description": "酸甜可口的经典菜，外酥里嫩，色泽红亮诱人。",
      "ingredients": ["猪小排 500g", "白醋 3勺", "白砂糖 4勺", "番茄酱 2勺", "生抽 1勺", "料酒 1勺", "姜片 适量", "淀粉 适量"],
      "ingredientsHighlight": ["猪小排", "糖醋"],
      "steps": [
        {
          "id": "step-1",
          "title": "腌制排骨",
          "content": "排骨冷水下锅焯水去腥，捞出后加料酒、生抽、姜片腌制20分钟。",
          "duration": 25
        },
        {
          "id": "step-2",
          "title": "调糖醋汁",
          "content": "碗中放入白醋、白糖、番茄酱、生抽和少许清水，搅拌均匀。",
          "duration": 2
        },
        {
          "id": "step-3",
          "title": "炸排骨",
          "content": "腌制好的排骨裹上干淀粉，油温六成热下锅炸至金黄色捞出，油温升高再复炸一次。",
          "duration": 8
        },
        {
          "id": "step-4",
          "title": "裹汁出锅",
          "content": "锅中留少许油，倒入糖醋汁小火熬至浓稠，放入排骨快速翻炒均匀即可。",
          "duration": 4
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1544025162-d76694265947?w=400&h=250&fit=crop",
      "rating": 4.6,
