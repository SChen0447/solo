    {
      "id": "dish-006",
      "name": "麻婆豆腐",
      "description": "麻辣鲜香，嫩豆腐入口即化，川菜家常代表。",
      "ingredients": ["嫩豆腐 1块", "猪肉末 100g", "豆瓣酱 2勺", "花椒粉 适量", "葱姜蒜 适量", "生抽 1勺", "淀粉水 适量"],
      "ingredientsHighlight": ["嫩豆腐", "豆瓣酱"],
      "steps": [
        {
          "id": "step-1",
          "title": "处理豆腐",
          "content": "豆腐切小块，淡盐水浸泡10分钟，焯水后捞出备用。",
          "duration": 13
        },
        {
          "id": "step-2",
          "title": "炒肉末",
          "content": "热锅放油，下入肉末炒散变色，加豆瓣酱炒出红油。",
          "duration": 4
        },
        {
          "id": "step-3",
          "title": "烧豆腐",
          "content": "加入葱姜蒜爆香，加适量清水，放入豆腐、生抽，小火煮5分钟入味。",
          "duration": 6
        },
        {
          "id": "step-4",
          "title": "勾芡出锅",
          "content": "分两次淋入淀粉水勾芡，撒上花椒粉即可出锅。",
          "duration": 2
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1585032226651-759b368d7246?w=400&h=280&fit=crop",
      "rating": 4.4,
