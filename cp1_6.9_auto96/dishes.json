    {
      "id": "dish-004",
      "name": "宫保鸡丁",
      "description": "川菜经典名菜，鸡肉滑嫩，花生酥脆，酸甜微辣。",
      "ingredients": ["鸡胸肉 300g", "花生米 50g", "干辣椒 10个", "花椒 1勺", "葱姜蒜 适量", "生抽 1勺", "醋 1勺", "糖 1勺", "淀粉 适量"],
      "ingredientsHighlight": ["鸡胸肉", "花生米"],
      "steps": [
        {
          "id": "step-1",
          "title": "腌制鸡肉",
          "content": "鸡胸肉切丁，加料酒、生抽、淀粉抓匀腌制15分钟。",
          "duration": 18
        },
        {
          "id": "step-2",
          "title": "调碗汁",
          "content": "碗中放入生抽、醋、糖、淀粉和少许水，搅拌均匀备用。",
          "duration": 2
        },
        {
          "id": "step-3",
          "title": "炒鸡丁",
          "content": "热锅多放油，下入鸡丁滑散至变色盛出。",
          "duration": 4
        },
        {
          "id": "step-4",
          "title": "爆香料",
          "content": "锅中留底油，小火炒香干辣椒、花椒和葱姜蒜。",
          "duration": 2
        },
        {
          "id": "step-5",
          "title": "翻炒出锅",
          "content": "倒入鸡丁、花生米，淋入碗汁，大火快速翻炒均匀即可。",
          "duration": 3
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1525755662778-989d0524087e?w=400&h=300&fit=crop",
      "rating": 4.8,
      "ratingCount": 156,
      "likes": 378,
      "comments": [
        {
          "id": "comment-4",
          "author": "川菜爱好者",
          "avatar": "https://api.dicebear.com/7.x/initials/svg?seed=%E5%B7%9D",
          "content": "味道很正宗！就是这个味儿~",
          "createdAt": "2024-01-10T20:00:00.000Z"
        }
