{
  "name": "virtual-perfumer-lab",
  "version": "1.0.0",
  "description": "基于浏览器的虚拟调香师实验室全栈应用",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "ts-node src/server.ts",
    "dev:client": "vite",
    "build": "tsc && vite build",
    "build:client": "vite build",
    "build:server": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "better-sqlite3": "9.0.0",
    "cors": "2.8.5",
    "@types/cors": "2.8.17"
  },
  "devDependencies": {
    "typescript": "5.5.0",
    "vite": "5.4.0",
    "@vitejs/plugin-react": "4.2.0",
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/node": "20.10.0",
    "@types/express": "4.17.21",
    "@types/better-sqlite3": "7.6.8",
    "ts-node": "10.9.2",
    "concurrently": "8.2.2"
  }
}
