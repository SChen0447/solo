{
  "name": "plant-diary",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:watch\" \"npm run client\"",
    "build:server": "tsc -p tsconfig.server.json",
    "server": "node server/dist/app.js",
    "server:watch": "node --watch --watch-path=server/src --watch-preserve-output -e \"require('child_process').execSync('npm run build:server', {stdio:'inherit'}); process.exit(0)\" 2>nul || npm run build:server && node --watch server/dist/app.js",
    "server:simple": "npm run build:server && node server/dist/app.js",
    "client": "vite",
    "build": "npm run build:server && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "express": "^4.18.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.2",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.7",
    "typescript": "^5.1.3",
    "vite": "^4.3.9"
  }
}
