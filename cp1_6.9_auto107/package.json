{
  "name": "collaborative-mindmap",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "client:dev": "vite",
    "server:dev": "npx tsx watch src/server.ts",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "4.18.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "socket.io": "4.7.0",
    "socket.io-client": "4.7.0",
    "cors": "2.8.5"
  },
  "devDependencies": {
    "@types/cors": "2.8.13",
    "@types/express": "4.17.17",
    "@types/node": "20.4.0",
    "@types/react": "18.2.14",
    "@types/react-dom": "18.2.6",
    "@vitejs/plugin-react": "4.0.1",
    "concurrently": "8.2.0",
    "tsx": "3.12.7",
    "typescript": "5.5.0",
    "vite": "5.4.0"
  }
}
