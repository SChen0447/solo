{
  "name": "beat-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "server:dev": "ts-node server/index.ts",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "build": "tsc -b && vite build",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "express": "4.18.2",
    "tone": "14.7.58",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.30",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.0",
    "ts-node": "^10.9.2",
    "typescript": "5.5.0",
    "vite": "5.4.0"
  }
}
